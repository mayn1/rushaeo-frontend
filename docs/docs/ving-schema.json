    "description": "Technical gap analysis schema for AI Act interface transparency standards.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://rushaeo.com"
    }
  ],
  "paths": {
    "/api/audit": {
      "post": {
