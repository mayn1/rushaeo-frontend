{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "/**",
        "headers": [
          {
            "key": "Link",
            "value": "</.well-known/ai-plugins.json>; rel=\"service-doc\", </docs/ving-schema.json>; rel=\"api-catalog\""
          }
        ]
      },
      {
        "source": "/docs/ving-schema.json",
        "headers": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ]
      },
      {
        "source": "/.well-known/openid-configuration",
        "headers": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ]
      }
    ]
  }
}
